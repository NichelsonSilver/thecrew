# Copia este archivo a .env y completa las claves. .env NO se versiona.

# --- Claves por proveedor (completa solo las que uses) -----------------------
# El pipeline usa TRES tiers; cada uno puede ir a un proveedor distinto.
GEMINI_API_KEY=...        # research (scouts) — tier gratis en aistudio.google.com
ANTHROPIC_API_KEY=sk-ant-...  # análisis / estrategia REALI
OPENAI_API_KEY=sk-...     # redacción web / RRSS

# --- Asignación de modelo por tier (opcional) --------------------------------
# Si no defines estas variables, el código usa estos mismos defaults económicos.
# Cambia de proveedor SIN tocar código: solo edita el string (prefijo = proveedor).
#   anthropic/claude-opus-4-8   anthropic/claude-haiku-4-5
#   openai/gpt-4o               openai/gpt-4o-mini
#   gemini/gemini-2.0-flash     gemini/gemini-1.5-flash
# (verifica los IDs vigentes en la doc de LiteLLM antes de fijarlos)
RESEARCH_MODEL=gemini/gemini-2.0-flash
ANALYSIS_MODEL=anthropic/claude-haiku-4-5
WRITING_MODEL=openai/gpt-4o-mini

# --- Búsqueda web (research en tiempo real) ----------------------------------
# https://serper.dev — plan free alcanza para pruebas.
SERPER_API_KEY=...

# --- Publicación (opcional, para cuando se cablee el despliegue real) ---------
# NOTION_API_KEY=...
# LINKEDIN_ACCESS_TOKEN=...
# X_BEARER_TOKEN=...

# --- Observabilidad (opcional) -----------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=...
